{
  "name": "@plannotator/pi-extension",
  "version": "0.19.22-pk.2",
  "type": "module",
  "description": "Plannotator extension for Pi coding agent - interactive plan review with visual annotation",
  "author": "kingkillery",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingkillery/pk-plannotator.git",
    "directory": "apps/pi-extension"
  },
  "homepage": "https://github.com/kingkillery/pk-plannotator",
  "bugs": {
    "url": "https://github.com/kingkillery/pk-plannotator/issues"
  },
  "keywords": ["pi-package", "plannotator", "plan-review", "ai-agent", "coding-agent"],
  "pi": {
    "extensions": ["./"],
    "skills": ["./skills"]
  },
  "files": [
    "index.ts",
    "plannotator-browser.ts",
    "plannotator-events.ts",
    "server.ts",
    "tool-scope.ts",
    "config.ts",
    "plannotator.json",
    "server/",
    "generated/",
    "README.md",
    "plannotator.html",
    "review-editor.html",
    "skills/"
  ],
  "scripts": {
    "build": "cp ../hook/dist/index.html plannotator.html && cp ../hook/dist/review.html review-editor.html && rm -rf skills && cp -r ../skills skills && bash vendor.sh",
    "prepublishOnly": "cd ../.. && bun run build:pi"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.53.0"
  }
}
